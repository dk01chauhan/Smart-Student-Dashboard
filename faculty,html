<!DOCTYPE html>
<html>
<body>

<script>
let u = JSON.parse(localStorage.getItem("user"));
if(!u || u.role!=="faculty") location.href="index.html";
</script>

<h2>Faculty Panel</h2>

<input id="sid" placeholder="Student ID">
<input id="sub" placeholder="Subject">
<input id="m" placeholder="Marks">

<button onclick="add()">Add</button>

<script>
function add(){
fetch("http://localhost:8080/addMarks",{
method:"POST",
headers:{"Content-Type":"application/json"},
body:JSON.stringify({
studentId:sid.value,
subject:sub.value,
marks:m.value
})
}).then(r=>r.text()).then(alert);
}
</script>

</body>
</html>